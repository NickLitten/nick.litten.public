{
    "project": {
        "name": "Nick Litten IBM i Project",
        "author": "Nick Litten",
        "description": "Modern IBM i application development with best practices",
        "version": "1.0.0"
    },
    "coding_standards": {
        "enabled": true,
        "auto_apply": true,
        "standards_directory": ".bob",
        "languages": {
            "rpgle": {
                "standard_file": "coding-standards-rpgle.md",
                "template_file": "templates/template.rpgle",
                "file_extensions": [
                    ".rpgle",
                    ".sqlrpgle"
                ],
                "comment_style": "///",
                "separator_char": "-",
                "copyright_format": "ctl-opt copyright('v.{version} - {description}');",
                "author": "Nick Litten"
            },
            "clle": {
                "standard_file": "coding-standards-clle.md",
                "template_file": "templates/template.clle",
                "file_extensions": [
                    ".clle",
                    ".cl"
                ],
                "comment_style": "/* */",
                "separator_char": "-",
                "copyright_format": "COPYRIGHT TEXT('v.{version} - {description}')",
                "author": "Nick Litten"
            },
            "dds": {
                "standard_file": "coding-standards-dds.md",
                "template_file": "templates/template.dds",
                "file_extensions": [
                    ".pf",
                    ".lf",
                    ".dspf",
                    ".prtf"
                ],
                "comment_style": "A*",
                "separator_char": "-",
                "author": "Nick Litten"
            },
            "sql": {
                "standard_file": "coding-standards-sql.md",
                "template_file": "templates/template.sql",
                "file_extensions": [
                    ".sql"
                ],
                "comment_style": "--",
                "separator_char": "-",
                "author": "Nick Litten"
            }
        }
    },
    "documentation": {
        "auto_generate": true,
        "header_required": true,
        "modification_history_required": true,
        "version_calculation": "auto",
        "version_format": "v.{count:03d}",
        "date_format": "YYYY.MM.DD",
        "sections": {
            "rpgle": [
                "Program/Service Name",
                "Description",
                "Purpose",
                "Features",
                "Usage",
                "Parameters",
                "Returns",
                "Dependencies",
                "Compilation",
                "Author",
                "Modification History"
            ],
            "clle": [
                "Program Name",
                "Description",
                "Purpose",
                "Features",
                "Usage",
                "Parameters",
                "Returns",
                "Dependencies",
                "Compilation",
                "Author",
                "Modification History"
            ],
            "dds": [
                "File Name",
                "Description",
                "Purpose",
                "Features",
                "Key Fields",
                "Indexes",
                "Compilation",
                "Author",
                "Modification History"
            ],
            "sql": [
                "Script Name",
                "Description",
                "Purpose",
                "Features",
                "Usage",
                "Dependencies",
                "Author",
                "Modification History"
            ]
        }
    },
    "code_scanning": {
        "enabled": true,
        "scan_on_save": true,
        "rules": {
            "separator_character": {
                "enabled": true,
                "severity": "error",
                "message": "Use dash (-) for separators, not equals (=)",
                "pattern": "={3,}",
                "replacement": "---"
            },
            "comment_style": {
                "enabled": true,
                "severity": "warning",
                "check_file_header": true,
                "check_procedure_header": true
            },
            "copyright_statement": {
                "enabled": true,
                "severity": "warning",
                "required": true,
                "auto_update_version": true
            },
            "author_field": {
                "enabled": true,
                "severity": "warning",
                "required": true,
                "default_author": "Nick Litten"
            },
            "modification_history": {
                "enabled": true,
                "severity": "warning",
                "required": true,
                "auto_add_entry": true
            },
            "naming_conventions": {
                "enabled": true,
                "severity": "info",
                "check_variables": true,
                "check_procedures": true,
                "check_constants": true
            },
            "modern_syntax": {
                "enabled": true,
                "severity": "info",
                "prefer_dcl": true,
                "prefer_qualified_ds": true,
                "avoid_goto": true,
                "avoid_tag": true
            }
        }
    },
    "auto_correction": {
        "enabled": true,
        "corrections": {
            "separator_lines": {
                "enabled": true,
                "find": "={3,}",
                "replace": "---",
                "scope": "comments"
            },
            "comment_blocks": {
                "enabled": true,
                "auto_format": true,
                "align_comments": true
            },
            "indentation": {
                "enabled": true,
                "spaces": 3,
                "align_declarations": true
            },
            "trailing_whitespace": {
                "enabled": true,
                "remove_on_save": true
            }
        }
    },
    "template_insertion": {
        "enabled": true,
        "auto_insert_header": true,
        "auto_insert_procedure_doc": true,
        "trigger": "on_new_file",
        "placeholders": {
            "author": "Nick Litten",
            "date": "{current_date}",
            "version": "v.001",
            "description": "{prompt}"
        }
    },
    "version_control": {
        "track_modifications": true,
        "auto_increment_version": true,
        "update_copyright": true,
        "add_history_entry": true,
        "history_format": "v.{version} {date} - {author} - {description}"
    },
    "code_generation": {
        "enabled": true,
        "templates": {
            "procedure": {
                "include_header": true,
                "include_error_handling": true,
                "include_validation": true
            },
            "data_structure": {
                "prefer_qualified": true,
                "include_template": true
            },
            "constants": {
                "group_by_purpose": true,
                "include_comments": true
            }
        }
    },
    "best_practices": {
        "enforce": true,
        "checks": {
            "use_const_for_literals": true,
            "use_qualified_ds": true,
            "use_modern_syntax": true,
            "include_error_handling": true,
            "validate_parameters": true,
            "use_meaningful_names": true,
            "avoid_magic_numbers": true,
            "include_audit_fields": true
        }
    },
    "performance": {
        "suggestions_enabled": true,
        "checks": {
            "sql_efficiency": true,
            "string_operations": true,
            "loop_optimization": true,
            "memory_usage": true
        }
    },
    "integration": {
        "vscode": {
            "enabled": true,
            "format_on_save": true,
            "lint_on_save": true
        },
        "git": {
            "enabled": true,
            "auto_commit_message": "BOB: {action} - {description}"
        }
    }
}