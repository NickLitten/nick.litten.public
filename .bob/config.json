{
    "project": {
        "name": "NICKLITTEN",
        "description": "Nick Litten Public GitHub Code Samples",
        "language": "IBM i (RPG, CL, SQL, DDS)",
        "author": "Nick Litten",
        "website": "https://www.nicklitten.com"
    },
    "coding_standards": {
        "enabled": true,
        "standards_file": ".bob/coding-standards.md",
        "auto_apply": true,
        "strict_mode": false
    },
    "documentation": {
        "format": {
            "rpgle": "triple_slash",
            "sqlrpgle": "triple_slash",
            "clle": "block_comment",
            "dds": "asterisk",
            "sql": "double_dash"
        },
        "line_separator": "-",
        "line_separator_forbidden": "=",
        "author_name": "Nick Litten",
        "require_header": true,
        "require_modification_history": true,
        "require_purpose_section": true,
        "require_features_section": true,
        "require_usage_section": true
    },
    "version_control": {
        "auto_calculate_version": true,
        "version_format": "V.XXX",
        "initial_version": "V.000",
        "count_from_history": true
    },
    "copyright": {
        "auto_insert": true,
        "author": "Nick Litten",
        "year": "auto",
        "website": "https://www.nicklitten.com",
        "format": {
            "rpgle": "ctl-opt copyright('{program} | {version} | {description}');",
            "sqlrpgle": "ctl-opt copyright('{program} | {version} | {description}');",
            "clle": "COPYRIGHT TEXT('{program} Ver:{version} {description}')"
        }
    },
    "templates": {
        "directory": "templates",
        "files": {
            "rpgle": "template.rpgle",
            "sqlrpgle": "template.sqlrpgle",
            "clle": "template.clle",
            "dspf": "template.dspf",
            "pf": "template.pf",
            "table": "template.table"
        }
    },
    "code_review": {
        "auto_scan": true,
        "rules": {
            "documentation": {
                "missing_header": "error",
                "missing_modification_history": "warning",
                "missing_purpose": "warning",
                "missing_features": "info",
                "incomplete_description": "warning"
            },
            "code_quality": {
                "magic_numbers": "warning",
                "hardcoded_values": "warning",
                "missing_error_handling": "error",
                "inconsistent_naming": "warning",
                "missing_comments": "info"
            },
            "best_practices": {
                "fixed_format_rpg": "error",
                "no_main_procedure": "warning",
                "unqualified_data_structures": "warning",
                "missing_sql_options": "warning",
                "no_activation_group": "warning"
            }
        }
    },
    "auto_corrections": {
        "enabled": true,
        "rules": {
            "insert_missing_header": true,
            "update_copyright_version": true,
            "fix_indentation": true,
            "add_section_separators": true,
            "convert_to_free_format": false,
            "add_procedure_documentation": true,
            "standardize_naming": false
        }
    },
    "file_patterns": {
        "rpgle": [
            "**/*.rpgle",
            "**/*.pgm.rpgle",
            "**/*.mod.rpgle",
            "**/*.srvpgm.rpgle"
        ],
        "sqlrpgle": [
            "**/*.sqlrpgle",
            "**/*.pgm.sqlrpgle",
            "**/*.mod.sqlrpgle",
            "**/*.srvpgm.sqlrpgle"
        ],
        "clle": [
            "**/*.clle",
            "**/*.pgm.clle",
            "**/*.cmd.clle"
        ],
        "dspf": [
            "**/*.dspf"
        ],
        "pf": [
            "**/*.pf"
        ],
        "table": [
            "**/*.table"
        ],
        "sql": [
            "**/*.sql"
        ]
    },
    "exclusions": {
        "directories": [
            ".vscode",
            ".git",
            "node_modules",
            ".bob"
        ],
        "files": [
            "**/*NOCOMPILE*",
            "**/legacy/**"
        ]
    },
    "naming_conventions": {
        "programs": "UPPERCASE",
        "procedures": "PascalCase",
        "variables": "camelCase",
        "constants": "UPPER_SNAKE_CASE",
        "data_structures": "PascalCase",
        "file_fields": "UPPERCASE"
    },
    "formatting": {
        "rpgle": {
            "indent": "| ",
            "section_separator": "// --------------------------------------------------------------------------",
            "procedure_separator": "// --------------------------------------------------------------------------",
            "max_line_length": 100,
            "line_separator_char": "-",
            "forbidden_separator_char": "="
        },
        "clle": {
            "section_separator": "/* --------------------------------------------------------------------------",
            "max_line_length": 80,
            "line_separator_char": "-",
            "forbidden_separator_char": "="
        },
        "dds": {
            "header_separator": "      * --------------------------------------------------------------------------",
            "line_separator_char": "-",
            "forbidden_separator_char": "="
        },
        "sql": {
            "section_separator": "-- --------------------------------------------------------------------------",
            "indent": "    ",
            "line_separator_char": "-",
            "forbidden_separator_char": "="
        }
    },
    "integration": {
        "vscode": {
            "enable_snippets": true,
            "enable_linting": true,
            "enable_formatting": true
        },
        "git": {
            "auto_update_version_on_commit": true,
            "require_modification_history_entry": false
        }
    },
    "ai_assistant": {
        "name": "BOB",
        "role": "IBM i Development Assistant",
        "capabilities": [
            "code_review",
            "documentation_generation",
            "modernization_suggestions",
            "best_practices_enforcement",
            "template_application",
            "version_management",
            "sqlrpgle_conversion",
            "native_io_detection"
        ],
        "preferences": {
            "verbose_explanations": true,
            "suggest_improvements": true,
            "auto_apply_standards": true,
            "educational_mode": true
        }
    },
    "custom_instructions": {
        "rpg_development": {
            "enabled": true,
            "priority": "high",
            "description": "Focused RPG programming with SQLRPGLE preference and strict template adherence",
            "instructions": [
                "ALWAYS prefer SQLRPGLE over native file I/O operations (CHAIN, READ, WRITE, UPDATE, DELETE)",
                "When generating RPG code, use SQL embedded statements for all database access",
                "ALL new files must follow the templates in .bob/templates/ directory",
                "ALL code must adhere to coding standards in .bob/coding-standards-*.md files",
                "Use modern RPG syntax: dcl-s, dcl-ds, dcl-pi, dcl-proc",
                "Include comprehensive error handling with SQLSTATE checking",
                "Follow Nick Litten's naming conventions and documentation standards",
                "Auto-insert proper file headers from templates",
                "Maintain modification history in v.XXX format",
                "Use qualified data structures for all complex data",
                "Include SQL error handling in all database operations",
                "Prefer SQL cursors over native file positioning",
                "Use SQL transactions for data integrity"
            ],
            "file_io_conversion": {
                "enabled": true,
                "suggest_sql_alternatives": true,
                "auto_detect_native_io": true,
                "patterns": {
                    "CHAIN": {
                        "sql_alternative": "exec sql SELECT * INTO :dataStructure FROM {table} WHERE {key} = :keyValue;",
                        "description": "Use SQL SELECT with INTO for single record retrieval",
                        "error_handling": "Check SQLSTATE after SELECT"
                    },
                    "READ": {
                        "sql_alternative": "exec sql DECLARE c1 CURSOR FOR SELECT * FROM {table} ORDER BY {key}; exec sql OPEN c1; exec sql FETCH c1 INTO :dataStructure;",
                        "description": "Use SQL cursor for sequential reading",
                        "error_handling": "Check SQLSTATE = '02000' for end of data"
                    },
                    "READE": {
                        "sql_alternative": "exec sql SELECT * INTO :dataStructure FROM {table} WHERE {key} = :keyValue ORDER BY {key};",
                        "description": "Use SQL SELECT with WHERE clause for equal key reads",
                        "error_handling": "Check SQLSTATE after SELECT"
                    },
                    "WRITE": {
                        "sql_alternative": "exec sql INSERT INTO {table} VALUES (:dataStructure);",
                        "description": "Use SQL INSERT for adding records",
                        "error_handling": "Check SQLSTATE for duplicate key or constraint violations"
                    },
                    "UPDATE": {
                        "sql_alternative": "exec sql UPDATE {table} SET field1 = :value1, field2 = :value2 WHERE {key} = :keyValue;",
                        "description": "Use SQL UPDATE with WHERE clause",
                        "error_handling": "Check SQLSTATE and SQLERRD(3) for rows affected"
                    },
                    "DELETE": {
                        "sql_alternative": "exec sql DELETE FROM {table} WHERE {key} = :keyValue;",
                        "description": "Use SQL DELETE with WHERE clause",
                        "error_handling": "Check SQLSTATE and SQLERRD(3) for rows affected"
                    },
                    "SETLL": {
                        "sql_alternative": "exec sql DECLARE cursor FOR SELECT * FROM {table} WHERE {key} >= :keyValue ORDER BY {key};",
                        "description": "Use SQL cursor with >= condition for positioning",
                        "error_handling": "Check SQLSTATE after OPEN"
                    },
                    "SETGT": {
                        "sql_alternative": "exec sql DECLARE cursor FOR SELECT * FROM {table} WHERE {key} > :keyValue ORDER BY {key};",
                        "description": "Use SQL cursor with > condition for positioning",
                        "error_handling": "Check SQLSTATE after OPEN"
                    }
                }
            },
            "template_enforcement": {
                "enabled": true,
                "strict_mode": true,
                "template_directory": ".bob/templates",
                "required_templates": {
                    "rpgle": "template.rpgle",
                    "sqlrpgle": "template.sqlrpgle",
                    "clle": "template.clle",
                    "pf": "template.pf",
                    "table": "template.table"
                },
                "required_sections": [
                    "file_header",
                    "description",
                    "purpose",
                    "features",
                    "usage",
                    "modification_history",
                    "copyright_statement",
                    "author_field"
                ],
                "auto_apply_on_new_file": true
            },
            "coding_standards_enforcement": {
                "enabled": true,
                "strict_mode": true,
                "standards_directory": ".bob",
                "standards_files": [
                    "coding-standards-rpgle.md",
                    "coding-standards-sql.md",
                    "coding-standards-clle.md",
                    "coding-standards-dds.md"
                ],
                "auto_check_on_save": true,
                "auto_correct_violations": true
            }
        }
    }
}