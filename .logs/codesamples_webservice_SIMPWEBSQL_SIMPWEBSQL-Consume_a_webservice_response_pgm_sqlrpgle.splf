    32                                                                                                                      000034
    33 //-- SIMPWEBSQL - Consume an external internet webservice from                                                       000035
    34 //-- my IBMi System. Get the JSON result and let SQL decompose                                                       000036
    35 //-- that from JSON into fields that I can use.                                                                      000037
    36 dcl-proc SIMPWEBSQL;                                                                                                 000038
    37 dcl-pi SIMPWEBSQL end-pi;                                                                                            000039
    38                                                                                                                      000040
    39 // Output values                                                                                                     000041
    40 dcl-s g_firstname varchar(50);                                                                                       000042
    41 dcl-s g_surname varchar(50);                                                                                         000043
    42 dcl-s g_website varchar(50);                                                                                         000044
    43                                                                                                                      000045
    44 // result string humans who like to know what happened                                                               000046
    45 dcl-s g_result char(50);                                                                                             000047
    46                                                                                                                      000048
    47 monitor;                                                                                                             000049
    48                                                                                                                      000050
    49     // consume external webservice                                                                                   000051
    50     exec sql                                                                                                         000052
    51     select firstname, surname, website                                                                               000053
    52     into :g_firstname, :g_surname, :g_website                                                                        000054
    53     from JSON_TABLE( SYSTOOLS.HTTPGETCLOB (                                                                          000055
    54     'http://nicklitten.com/sample.json', null), '$'                                                                  000056
    55     COLUMNS(                                                                                                         000057
  Simply consume a webservice response from nicklitten dot com
