000123 **FREE                                                                                                               000123
000124 monitor;                                                                                             B01             000124
000125                                                                                                                      000125
000126     // consume external webservice                                                                                   000126
000127 //*    exec sql                                                                                                      000127
000128 //*    select firstname, surname, website                                                                            000128
000129 //*    into :g_firstname, :g_surname, :g_website                                                                     000129
000130 //*    from JSON_TABLE( SYSTOOLS.HTTPGETCLOB (                                                                       000130
000131 //*    'http://nicklitten.com/sample.json', null), '$'                                                               000131
000132 //*    COLUMNS(                                                                                                      000132
000133 //*    firstname VARCHAR(50) path '$.firstName',                                                                     000133
000134 //*    surname VARCHAR(50) path '$.surName',                                                                         000134
000135 //*    website VARCHAR(50) path '$.webSite'                                                                          000135
000136 //*    ) error on error                                                                                              000136
000137 //*    ) as x;                                                                                                       000137
000138           SQLER6 = -4;                                                          //SQL 1               01             000138
000139           SQLROUTE_CALL(                                                        //SQL                 01             000139
000140                SQLCA                                                            //SQL                 01             000140
000141              : SQL_00000                                                        //SQL                 01             000141
000142           );                                                                    //SQL                 01             000142
000143           IF SQL_00003 = '1';                                                   //SQL                B02             000143
000144           EVAL G_FIRSTNAME = SQL_00005;                                         //SQL                 02             000144
000145           EVAL G_SURNAME = SQL_00006;                                           //SQL                 02             000145
000146           EVAL G_WEBSITE = SQL_00007;                                           //SQL                 02             000146
000147           ENDIF;                                                                //SQL                E02             000147
000148                                                                                                                      000148
000149     Select;                                                                                          B02             000149
000150     when sqlcode = 0;                                                                                X02             000150
000151     g_result = 'Completed normally';                                                                  02             000151
000152     when sqlcode = 100;                                                                              X02             000152
000153     g_result = 'No data found';                                                                       02             000153
000154     when sqlcode > 0;                                                                                X02             000154
000155     g_result = 'Completed with warning';                                                              02             000155
000156     when sqlcode < 0;                                                                                X02             000156
000157     g_result = 'Did not complete normally';                                                           02             000157
000158     endsl;                                                                                           E02             000158
000159                                                                                                                      000159
000160     // Display values returned                                                                                       000160
000161     DSPLY sqlcode;                                                                                    01             000161
000162     DSPLY g_firstname;                                                                                01             000162
000163     DSPLY g_surname;                                                                                  01             000163
000164     DSPLY g_website;                                                                                  01             000164
000165                                                                                                                      000165
000166     return;                                                                                           01             000166
000167                                                                                                                      000167
000168 on-error ;                                                                                           X01             000168
000169     dump(a);                                                                                          01             000169
000170     dsply ('*** Webservice(' + %trim(psds.program) + ') has failed!');                                01             000170
000171 endmon ;                                                                                             E01             000171
000172                                                                                                                      000172
000173 end-proc;                                                                                                            000173
