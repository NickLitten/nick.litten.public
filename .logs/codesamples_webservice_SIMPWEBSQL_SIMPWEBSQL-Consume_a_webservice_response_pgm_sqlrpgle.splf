    56     firstname VARCHAR(50) path '$.firstName',                                                                        000058
    57     surname VARCHAR(50) path '$.surName',                                                                            000059
    58     website VARCHAR(50) path '$.webSite'                                                                             000060
    59     ) error on error                                                                                                 000061
    60     ) as x;                                                                                                          000062
    61                                                                                                                      000063
    62     Select;                                                                                                          000064
    63     when sqlcode = 0;                                                                                                000065
    64     g_result = 'Completed normally';                                                                                 000066
    65     when sqlcode = 100;                                                                                              000067
    66     g_result = 'No data found';                                                                                      000068
