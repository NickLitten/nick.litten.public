000034 //-- SIMPWEBSQL - Consume an external internet webservice from                                                       000034
000035 //-- my IBMi System. Get the JSON result and let SQL decompose                                                       000035
000036 //-- that from JSON into fields that I can use.                                                                      000036
000037        /SET CCSID(*CHAR:*JOBRUNMIX)                                                                                  000037
