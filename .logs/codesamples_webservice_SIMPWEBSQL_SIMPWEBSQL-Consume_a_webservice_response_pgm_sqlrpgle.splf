000048          SQLERRMC CHAR(70);                                                     //SQL                                000048
000049           SQLERM CHAR(70) OVERLAY(SQLERRMC);                                    //SQL                                000049
000050          SQLERRP CHAR(8);                                                       //SQL                                000050
000051           SQLERP CHAR(8) OVERLAY(SQLERRP);                                      //SQL                                000051
000052          SQLERR CHAR(24);                                                       //SQL                                000052
